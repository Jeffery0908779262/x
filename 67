<script>
function setNav(el) {
  document.querySelectorAll('.nav-item').forEach(n => {
    n.classList.remove('active');
    const dot = n.querySelector('.nav-active-dot');
    if (dot) dot.remove();
  });
  el.classList.add('active');
  const dot = document.createElement('div');
  dot.className = 'nav-active-dot';
  el.appendChild(dot);
}

function handleFile(input) {
  if (input.files && input.files[0]) {
    const file = input.files[0];
    const zone = document.querySelector('.upload-zone');
    zone.style.borderColor = '#66BB6A';
    zone.style.background = 'rgba(102,187,106,0.06)';
    const title = zone.querySelector('.upload-title');
    title.textContent = '✓ 已上傳：' + file.name.substring(0, 20) + (file.name.length > 20 ? '...' : '');
    const hint = zone.querySelector('.upload-hint');
    hint.textContent = '正在處理中，請稍候...';
    const btn = zone.querySelector('.upload-btn');
    btn.textContent = '⏳ 分析中...';
    btn.style.background = '#66BB6A';
  }
}

document.querySelector('.lang-toggle').addEventListener('click', function(e) {
  if (e.target.tagName === 'SPAN') {
    this.querySelectorAll('span').forEach(s => s.classList.remove('active'));
    e.target.classList.add('active');
  }
});
</script>
